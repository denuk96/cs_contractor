<% count = @skin_items.size %>
<div style="font-family: -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #1a1a1a; max-width: 640px; margin: 0 auto;">
  <h1 style="font-size: 18px; margin: 0 0 4px;">CS2 store update</h1>
  <p style="font-size: 14px; color: #555; margin: 0 0 20px;">
    <strong><%= count %></strong> item<%= "s" if count != 1 %> just left the in-game store — pulled directly, or the case/capsule it unboxes from was discontinued. Supply stops growing from here.
  </p>

  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="border-collapse: collapse; font-size: 13px;">
    <thead>
      <tr style="text-align: left; border-bottom: 2px solid #e5e5e5;">
        <th style="padding: 8px 10px;">Item</th>
        <th style="padding: 8px 10px;">Source</th>
        <th style="padding: 8px 10px;">Rarity</th>
        <th style="padding: 8px 10px; text-align: right;">Steam price</th>
      </tr>
    </thead>
    <tbody>
      <% @skin_items.each do |item| %>
        <% crates = Array(item.skin&.crates) %>
        <% market_url = "https://steamcommunity.com/market/listings/730/#{ERB::Util.url_encode(item.name)}" %>
        <tr style="border-bottom: 1px solid #f0f0f0;">
          <td style="padding: 8px 10px;">
            <a href="<%= market_url %>" style="color: #1a5fb4; text-decoration: none;"><%= item.name %></a>
          </td>
          <td style="padding: 8px 10px; color: #555;"><%= crates.any? ? crates.join(", ") : "Direct store item" %></td>
          <td style="padding: 8px 10px; color: #555;"><%= item.rarity %></td>
          <td style="padding: 8px 10px; text-align: right; white-space: nowrap;">
            <%= item.latest_steam_price ? "$#{format('%.2f', item.latest_steam_price)}" : "—" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <p style="font-size: 12px; color: #999; margin: 20px 0 0;">
    Sent by cs_contractor · SyncSteamStoreFlagsJob
  </p>
</div>
