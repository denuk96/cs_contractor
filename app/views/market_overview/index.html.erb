<div class="container mt-4" data-controller="popover">
  <h1 class="mb-1">Market Overview</h1>
  <p class="text-muted">
    Every tracked item rolled into one snapshot per day.
    <% if @latest_date %>
      Latest snapshot: <strong><%= @latest_date %></strong>.
    <% end %>
  </p>

  <div class="card mb-4">
    <div class="card-body">
      <%= form_with url: market_overview_path, method: :get, class: "row g-3" do |f| %>
        <div class="col-md-3">
          <%= f.label :start_date, "From", class: "form-label" %>
          <%= f.date_field :start_date, value: params[:start_date] || @start_date, class: "form-control" %>
        </div>
        <div class="col-md-3">
          <%= f.label :end_date, "To", class: "form-label" %>
          <%= f.date_field :end_date, value: params[:end_date] || @end_date, class: "form-control" %>
        </div>
        <div class="col-md-2">
          <%= f.label :stattrak, "StatTrak™", class: "form-label" %>
          <%= f.select :stattrak, [["Any", ""], ["Yes", "true"], ["No", "false"]], { selected: params[:stattrak] }, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.label :souvenir, "Souvenir", class: "form-label" %>
          <%= f.select :souvenir, [["Any", ""], ["Yes", "true"], ["No", "false"]], { selected: params[:souvenir] || "false" }, { class: "form-select" } %>
        </div>
        <div class="col-md-2">
          <%= f.label :in_game_store, "In-Store", class: "form-label" %>
          <%= f.select :in_game_store, [["Any", ""], ["Yes", "true"], ["No", "false"]], { selected: params[:in_game_store] }, { class: "form-select" } %>
        </div>
        <div class="col-12">
          <%= f.submit "Apply", class: "btn btn-primary" %>
          <%= link_to "Reset", market_overview_path, class: "btn btn-secondary" %>
        </div>
      <% end %>
    </div>
  </div>

  <% if @days.blank? %>
    <div class="alert alert-info">No market history in this range yet.</div>
  <% else %>
    <!-- KPI tiles: latest snapshot vs the first day in range -->
    <div class="row g-3 mb-5">
      <% @kpis.each do |kpi| %>
        <div class="col-6 col-md-3">
          <div class="card h-100">
            <div class="card-body">
              <div class="text-muted small text-uppercase"><%= kpi[:label] %></div>
              <div class="fs-4 fw-bold"><%= market_metric(kpi[:value], kpi[:format]) %></div>
              <% if kpi[:change] %>
                <span class="badge <%= kpi[:change] >= 0 ? 'bg-success' : 'bg-danger' %>">
                  <i class="bi bi-arrow-<%= kpi[:change] >= 0 ? 'up' : 'down' %>"></i>
                  <%= number_with_precision(kpi[:change].abs, precision: 1) %>%
                </span>
                <span class="text-muted small">vs <%= kpi[:compared_to] %></span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>

    <div class="row g-4 mb-4">
      <% @charts.each do |chart| %>
        <div class="col-lg-6">
          <h5>
            <%= chart[:title] %>
            <i class="bi bi-info-circle text-muted" data-bs-toggle="popover" data-bs-trigger="hover" title="<%= chart[:title] %>" data-bs-content="<%= chart[:hint] %>"></i>
          </h5>
          <%= line_chart chart[:data], colors: [chart[:color]], height: "260px", library: market_chart_library(chart) %>
        </div>
      <% end %>
    </div>

    <h4 class="mt-5">
      Per Item <small class="text-muted">(coverage-adjusted)</small>
      <i class="bi bi-info-circle text-muted" data-bs-toggle="popover" data-bs-trigger="hover" title="Why these exist" data-bs-content="The totals above move whenever the tracker starts following more items. Dividing by Items Tracked keeps a day comparable to one with different coverage."></i>
    </h4>
    <div class="row g-4">
      <% @per_item_charts.each do |chart| %>
        <div class="col-lg-4">
          <h6>
            <%= chart[:title] %>
            <i class="bi bi-info-circle text-muted" data-bs-toggle="popover" data-bs-trigger="hover" title="<%= chart[:title] %>" data-bs-content="<%= chart[:hint] %>"></i>
          </h6>
          <%= line_chart chart[:data], colors: [chart[:color]], height: "220px", library: market_chart_library(chart) %>
        </div>
      <% end %>
    </div>

    <!-- Day-by-day table: the non-color reading of the same data -->
    <h4 class="mt-5">Day by Day</h4>
    <div class="table-responsive mb-5" style="max-height: 500px;">
      <table class="table table-sm table-striped table-hover align-middle">
        <thead class="table-dark position-sticky top-0">
          <tr>
            <th>Date</th>
            <th class="text-end">Items</th>
            <th class="text-end">Sold</th>
            <th class="text-end">Offers</th>
            <th class="text-end">Buy Orders</th>
            <th class="text-end">Buy Wall</th>
            <th class="text-end">Turnover</th>
            <th class="text-end">Traded Value</th>
            <th class="text-end">Listed Value</th>
            <th class="text-end">Avg Price</th>
          </tr>
        </thead>
        <tbody>
          <% @days.reverse_each do |day| %>
            <tr>
              <td><%= day.date %></td>
              <td class="text-end"><%= number_with_delimiter(day.items_tracked) %></td>
              <td class="text-end"><%= number_with_delimiter(day.sold_volume) %></td>
              <td class="text-end"><%= number_with_delimiter(day.offer_volume) %></td>
              <td class="text-end"><%= number_with_delimiter(day.buy_order_volume) %></td>
              <td class="text-end"><%= market_metric(day.buy_wall_ratio, :ratio) %></td>
              <td class="text-end"><%= market_metric(day.turnover_rate, :percent) %></td>
              <td class="text-end"><%= market_metric(day.traded_value, :currency) %></td>
              <td class="text-end"><%= market_metric(day.listed_value, :currency) %></td>
              <td class="text-end"><%= market_metric(day.avg_price, :currency) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
